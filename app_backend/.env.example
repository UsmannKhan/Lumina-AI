# Backend environment configuration. Copy this file to `.env` and fill in
# real values.

# ──────────────────────────────────────────────────────────────────────────
# PostgreSQL — full connection string. From a Supabase project:
#   Project Settings → Database → Connection string → URI
# Example:
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────────
# Supabase Storage — service role key (NOT the anon key). From:
#   Project Settings → API → Project API keys → service_role
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# JWT auth. Generate a long random string for AUTH_SECRET_KEY, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=
AUTH_ALGORITHM=HS256

# ──────────────────────────────────────────────────────────────────────────
# Google Gemini — API key from https://aistudio.google.com/apikey
GOOGLE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# YouTube transcript via RapidAPI. Subscribe to a YouTube-transcript API
# on https://rapidapi.com (e.g. "YouTube Transcripts" by various providers),
# then copy the host + key from the API dashboard.
RAPIDAPI_KEY=
RAPIDAPI_HOST=

# ──────────────────────────────────────────────────────────────────────────
# Optional — Gotenberg URL for DOCX/PPTX → PDF conversion.
# Quickest setup is Docker:
#   docker run --rm -p 3000:3000 gotenberg/gotenberg:8
# If unset, DOCX/PPTX uploads will fail with a clear error.
GOTENBERG_URL=http://localhost:3000
